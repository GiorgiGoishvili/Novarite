# ─── App ────────────────────────────────────────────────────────────────────
# Your public deployment URL. Used for absolute links and CORS.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

# Public values — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Secret — NEVER expose to the browser, API routes only
# Used in lib/supabase/admin.ts which has a runtime guard that throws
# if accidentally imported in a client context.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Get your key at https://resend.com
# Required for sending real verification emails. If missing, codes are printed
# to the server console in development mode so you can still test the flow.
RESEND_API_KEY=

# The "From" address Resend uses. Must be a verified sender in your Resend dashboard.
EMAIL_FROM=Novarite <noreply@yourdomain.com>

# ─── SMS / Twilio Verify ─────────────────────────────────────────────────────
# Get credentials at https://console.twilio.com
# Required for sending real SMS verification codes via Twilio Verify.
# Create a Verify Service at console.twilio.com/verify/services to get the SID.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ─── Solana ──────────────────────────────────────────────────────────────────
# "devnet" | "mainnet-beta" | "testnet"
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Leave blank to use the default public RPC for the selected network.
# For production, use a paid RPC endpoint (Helius, Triton, QuickNode, etc.)
NEXT_PUBLIC_RPC_URL=

# On-chain Novarite program ID (leave blank while program is not deployed)
NEXT_PUBLIC_PROGRAM_ID=
