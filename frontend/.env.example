# ─── App ────────────────────────────────────────────────────────────────────
# Your public deployment URL. Used for absolute links and CORS.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Get your key at https://resend.com
# Required for sending real verification emails. If missing, codes are printed
# to the server console in development mode so you can still test the flow.
RESEND_API_KEY=

# The "From" address Resend uses. Must be a verified sender in your Resend dashboard.
EMAIL_FROM=Novarite <noreply@yourdomain.com>

# ─── SMS / Twilio ────────────────────────────────────────────────────────────
# Get credentials at https://console.twilio.com
# Required for sending real SMS verification codes.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Solana ──────────────────────────────────────────────────────────────────
# "devnet" | "mainnet-beta" | "testnet"
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Leave blank to use the default public RPC for the selected network.
# For production, use a paid RPC endpoint (Helius, Triton, QuickNode, etc.)
NEXT_PUBLIC_RPC_URL=

# On-chain Novarite program ID (leave blank while program is not deployed)
NEXT_PUBLIC_PROGRAM_ID=
